# Vox Biblios Configuration Example
# Copy this file to one of these locations:
#   - ~/.config/vox-biblios/config.env (recommended for global installation)
#   - ~/.vox-biblios.env (alternative for global installation)
#   - .env.local (for development in project directory)

# ============================================
# REQUIRED SETTINGS
# ============================================

# AWS Credentials (required for AWS Polly)
AWS_ACCESS_KEY=your_access_key_here
AWS_SECRET_KEY=your_secret_key_here

# ============================================
# AWS SETTINGS
# ============================================

# AWS region to use (default: us-east-1)
AWS_REGION=us-east-1

# S3 bucket name for storing audio files (default: vox-biblios)
S3_BUCKET=vox-biblios

# AWS Polly voice ID (default: Joanna)
# Popular options: Joanna, Matthew, Salli, Kimberly, Amy, Brian, Emma
POLLY_VOICE_ID=Joanna

# Polly engine type (default: neural)
# Options: neural, standard
POLLY_ENGINE=neural

# Audio output format (default: mp3)
# Options: mp3, ogg_vorbis, pcm
POLLY_FORMAT=mp3

# S3 key prefix for audio files (default: audio)
POLLY_KEY_PREFIX=audio

# ============================================
# STORAGE SETTINGS (S3-Compatible)
# ============================================
# Vox Biblios supports S3-compatible storage providers:
# - s3: Amazon S3 (default)
# - r2: Cloudflare R2 (zero egress fees)
# - b2: Backblaze B2 (low-cost storage)

# Storage provider (default: s3)
# Options: s3, r2, b2
STORAGE_PROVIDER=s3

# Storage bucket name (defaults to S3_BUCKET if not set)
# STORAGE_BUCKET=vox-biblios

# --- Cloudflare R2 Configuration ---
# Uncomment and configure for R2:
# STORAGE_PROVIDER=r2
# STORAGE_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=<r2_access_key_id>
# STORAGE_SECRET_KEY=<r2_secret_access_key>
# STORAGE_BUCKET=vox-biblios
# STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev
# STORAGE_REGION=auto

# --- Backblaze B2 Configuration ---
# Uncomment and configure for B2:
# STORAGE_PROVIDER=b2
# STORAGE_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
# STORAGE_ACCESS_KEY=<b2_application_key_id>
# STORAGE_SECRET_KEY=<b2_application_key>
# STORAGE_BUCKET=vox-biblios
# STORAGE_PUBLIC_URL=https://f002.backblazeb2.com/file/vox-biblios
# STORAGE_REGION=us-west-004

# Public URL base for accessing files (required for R2, optional for S3)
# This is used to generate URLs in the RSS feed
# STORAGE_PUBLIC_URL=https://your-custom-domain.com

# ============================================
# PODCAST SETTINGS
# ============================================

# Podcast title (default: Vox Biblios)
PODCAST_NAME=Vox Biblios

# Podcast description
PODCAST_DESCRIPTION=I speak with the voices of all the words I've seen.

# Podcast website URL
PODCAST_WEBSITE=vox-biblios.example.com

# Mark podcast as explicit content (default: false)
# Options: true, false
PODCAST_EXPLICIT=false

# Podcast artwork image URL (optional)
# PODCAST_IMAGE=https://example.com/podcast-artwork.jpg

# RSS feed filename (default: voxbiblios.rss)
RSS_FILENAME=voxbiblios.rss

# ============================================
# TEXT PROCESSING SETTINGS
# ============================================

# Number of characters to include in episode descriptions (default: 100)
PREVIEW_LENGTH=100

# Maximum character size for Polly text chunks (default: 90000)
# Note: Polly has a 100,000 character limit per request
CHUNK_SIZE=90000

# ============================================
# LOGGING SETTINGS
# ============================================

# Logging level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file name (default: vox_biblios.log)
LOG_FILE=vox_biblios.log

# Log directory (default: logs)
LOG_DIR=logs
