# Vox Biblios Configuration Example
# Copy this file to one of these locations:
#   - ~/.config/vox-biblios/config.env (recommended for global installation)
#   - ~/.vox-biblios.env (alternative for global installation)
#   - .env.local (for development in project directory)

# ============================================
# TTS SETTINGS
# ============================================

# Default TTS provider (default: pocket-tts)
# Options: pocket-tts, kokoro, polly, say
TTS_PROVIDER=pocket-tts

# Default Pocket TTS voice (default: alba)
# Options: alba, marius, javert, jean, fantine, cosette, eponine, azelma
POCKET_TTS_VOICE=alba

# Pocket TTS model checkpoint (default: english_2026-04)
POCKET_TTS_MODEL=english_2026-04

# ============================================
# AWS CREDENTIALS
# ============================================
# Only required for S3/RSS publishing or the Polly provider.
# Leave blank for local-only usage (process --output-dir ...).

AWS_ACCESS_KEY=your_access_key_here
AWS_SECRET_KEY=your_secret_key_here

# ============================================
# AWS SETTINGS
# ============================================

# AWS region to use (default: us-east-1)
AWS_REGION=us-east-1

# S3 bucket name for storing audio files (default: vox-biblios)
S3_BUCKET=vox-biblios

# AWS Polly voice ID (default: Joanna)
# Popular options: Joanna, Matthew, Salli, Kimberly, Amy, Brian, Emma
POLLY_VOICE_ID=Joanna

# Polly engine type (default: neural)
# Options: neural, standard
POLLY_ENGINE=neural

# Audio output format (default: mp3)
# Options: mp3, ogg_vorbis, pcm
POLLY_FORMAT=mp3

# S3 key prefix for audio files (default: audio)
POLLY_KEY_PREFIX=audio

# ============================================
# PODCAST SETTINGS
# ============================================

# Podcast title (default: Vox Biblios)
PODCAST_NAME=Vox Biblios

# Podcast description
PODCAST_DESCRIPTION=I speak with the voices of all the words I've seen.

# Podcast website URL
PODCAST_WEBSITE=vox-biblios.example.com

# Mark podcast as explicit content (default: false)
# Options: true, false
PODCAST_EXPLICIT=false

# Podcast artwork image URL (optional)
# PODCAST_IMAGE=https://example.com/podcast-artwork.jpg

# RSS feed filename (default: voxbiblios.rss)
RSS_FILENAME=voxbiblios.rss

# ============================================
# TEXT PROCESSING SETTINGS
# ============================================

# Number of characters to include in episode descriptions (default: 100)
PREVIEW_LENGTH=100

# Upper bound on text chunk size (default: 90000)
# Each TTS provider declares its own (smaller) chunk limit; chunks are
# synthesized separately and concatenated into one MP3 per article.
CHUNK_SIZE=90000

# ============================================
# LOGGING SETTINGS
# ============================================

# Logging level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file name (default: vox_biblios.log)
LOG_FILE=vox_biblios.log

# Log directory (default: logs)
LOG_DIR=logs
