# Required
AWS_ACCESS_KEY=your_access_key_here
AWS_SECRET_KEY=your_secret_key_here

# Optional - Customize these
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
POLLY_VOICE_ID=Joanna
POLLY_ENGINE=neural
POLLY_FORMAT=mp3
POLLY_KEY_PREFIX=audio

# Podcast Settings
PODCAST_NAME=My Podcast
PODCAST_DESCRIPTION=Description here
PODCAST_WEBSITE=https://your-website.com
PODCAST_IMAGE=https://your-image-url.com/image.png
RSS_FILENAME=voxbiblios.rss

# Processing Settings
CHUNK_SIZE=90000
PREVIEW_LENGTH=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=vox_biblios.log
LOG_DIR=logs